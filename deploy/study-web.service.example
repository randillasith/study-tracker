[Unit]
Description=Study Tracker Web Dashboard
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/study-tracker
EnvironmentFile=/home/ubuntu/study-tracker/.env
ExecStart=/home/ubuntu/study-tracker/.venv/bin/gunicorn -w 2 -b 127.0.0.1:5052 study_web.app:app
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
