# Telegram bot token from @BotFather
STUDY_BOT_TOKEN=123456:replace_me

# Flask session secret; generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_me

# Optional Gemini key for AI Coach
GEMINI_API_KEY=

# Optional DB path. Default: ./data/study.db
STUDY_DB_PATH=/home/ubuntu/study-tracker/data/study.db

# Secret header for n8n reminder endpoint /api/notify/check
STUDY_NOTIFY_KEY=replace_me

# Bot login links expire after this many minutes
LOGIN_TOKEN_TTL_MINUTES=15

# Web app port
PORT=5052

# Shared secret for n8n/reminder checks. Requests must send X-Study-Notify-Key.
STUDY_NOTIFY_KEY=replace_me
LOGIN_TOKEN_TTL_MINUTES=15
