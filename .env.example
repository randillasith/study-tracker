# Telegram bot token from @BotFather
STUDY_BOT_TOKEN=123456:replace_me

# Flask session secret; generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_me

# Optional Gemini key for AI Coach
GEMINI_API_KEY=

# Optional DB path. Default: ./data/study.db
STUDY_DB_PATH=/home/ubuntu/study-tracker/data/study.db

# Web app port
PORT=5052
